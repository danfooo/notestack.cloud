# ── Local development ─────────────────────────────────────────────────────────

# Signs and verifies login tokens. Any long random string works locally.
JWT_SECRET=change-me-in-production

# Powers AI features (think prompts, MCP). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Your account credentials for the seed script (npm run seed)
SEED_EMAIL=you@example.com
SEED_PASSWORD=yourpassword
SEED_NAME=Your Name

# ── Production only (set via `fly secrets set`, not needed locally) ────────────

# Transactional email via Resend (https://resend.com). Without this, emails log to console only.
# RESEND_API_KEY=re_your_key_here

# The "from" address on all outgoing emails.
# EMAIL_FROM=notestack.cloud <noreply@notestack.cloud>

# Public URL of the app — embedded in email links (password reset, invites).
# APP_URL=https://notestack.cloud

# Google OAuth client ID — required for Sign in with Google.
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Set automatically by Fly.io (do not set manually) ─────────────────────────

# NODE_ENV=production
# PORT=3000
# DATA_DIR=/app/server/data
