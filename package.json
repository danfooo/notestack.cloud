{
  "name": "notestack.cloud",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "predev": "lsof -ti :3000 | xargs kill -9 2>/dev/null; true",
    "dev": "concurrently --kill-others \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "start": "cd server && npm start",
    "test": "cd server && npm test",
    "test:leave": "cd server && npm run test:leave",
    "db:snapshot": "DIR=db-snapshot-$(date +%Y%m%d-%H%M%S) && mkdir -p $DIR && fly ssh sftp get /app/server/data/notestack.db $DIR/notestack.db && echo \"Snapshot saved to $DIR\""
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
